class Solution:
    def add(self,num):
        ans = 0
        while num > 0:
            last_digit = num % 10
            ans += last_digit
            num = num // 10
        return ans
    def addDigits(self, num: int) -> int:
       
        while num > 9 :
            num = self.add(num)
        
        return num
            
# Time complexity is O(numberofdigits) and space compelxity is O(1)

class Solution:
    def addDigits(self, num: int) -> int:
        if num == 0 : return 0
        elif num % 9 == 0 : return 9
        else : return num % 9
# Time and space complexity is O(1)